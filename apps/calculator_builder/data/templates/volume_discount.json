{
  "id": "tpl_volume_discount",
  "name": "Volume discount (IF tier)",
  "description": "Discount tiers using IF. Total = qty * unit_price * (1 - discount).",
  "require_email_for_full_result": true,
  "webhook_url": "",
  "payment": {
    "enabled": true,
    "mode": "required",
    "amount_cents": 4900,
    "currency": "usd",
    "success_message": "Payment received. Full discount report unlocked."
  },
  "fields": [
    {
      "key": "qty",
      "label": "Quantity",
      "type": "slider",
      "min": 1,
      "max": 1000,
      "step": 1,
      "default": 20
    },
    {
      "key": "unit_price",
      "label": "Unit price",
      "type": "number",
      "min": 0,
      "max": 100000,
      "step": 1,
      "default": 100
    },
    {
      "key": "discount",
      "label": "Discount rate",
      "type": "result",
      "format": "percent",
      "formula": "IF(qty >= 100, 0.2, IF(qty >= 50, 0.1, IF(qty >= 10, 0.05, 0)))"
    },
    {
      "key": "total",
      "label": "Total after discount",
      "type": "result",
      "format": "currency",
      "formula": "qty * unit_price * (1 - discount)"
    }
  ]
}
